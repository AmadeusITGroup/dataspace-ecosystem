@startuml

skinParam NoteBackgroundColor WhiteSmoke
skinParam NoteFontColor Black
skinParam ParticipantBackgroundColor WhiteSmoke
skinParam ActorBackgroundColor WhiteSmoke
skinParam AgentBackgroundColor White
skinParam AgentBorderColor SkyBlue
skinparam shadowing false
skinparam BoxPadding 10

!define ParticipantAColor f8f2ff
!define ParticipantBColor d9edff
!define VCIssuersColor D5F5E3
!define DataspaceAuthorityColor FCF3CF
!define WarningColor Business
!define LeadColor Technology

autonumber

box "VC Issuers" #VCIssuersColor
    participant VcIssuersDidDocument as "DID document"
end box

box "Participant ecosystem" #ParticipantAColor
    database ParticipantADatabase as "Database"
    database ParticipantAVault as "Vault"
    participant ParticipantAIdentityHub as "Identity Hub" #Business
    participant ParticipantAControlPlane as "Control Plane" #Business
    participant ParticipantADataPlane as "Data Plane" #Business
end box

'box "Participant B ecosystem" #ParticipantBColor
'    participant ParticipantBDataPlane as "Data Plane" #Business
'    participant ParticipantBControlPlane as "Control Plane" #Business
'    participant ParticipantBIdentityHub as "Identity Hub" #Business
'    participant ParticipantBDidServer as "DID Server" #Business
'end box

box "Dse Federated Services" #DataspaceAuthorityColor
    participant FederatedCatalog as "Federated Catalog" #Business
    participant AuthorityIdentityHub as "Identity Hub" #Business
    participant ParticipantRegistry as "Participant Registry"
end box

autonumber 1

FederatedCatalog ->> ParticipantRegistry : request participants list
activate FederatedCatalog
activate ParticipantRegistry
ParticipantRegistry -->> FederatedCatalog : list of participants DIDs
deactivate ParticipantRegistry

group For each participant
    FederatedCatalog ->> ParticipantAIdentityHub : query DID document
    activate ParticipantAIdentityHub
    ParticipantAIdentityHub -->> FederatedCatalog : DID document containing Control Plane url
    deactivate ParticipantAIdentityHub
    FederatedCatalog ->> ParticipantAControlPlane : query datasets
    activate ParticipantAControlPlane
    group Verify VCs
        ParticipantAControlPlane ->> AuthorityIdentityHub : fetch Verifiable Credentials
        activate AuthorityIdentityHub
        AuthorityIdentityHub -->> ParticipantAControlPlane : return list of VCs
        deactivate AuthorityIdentityHub
        ParticipantAControlPlane ->> ParticipantAControlPlane : resolve issuers\nDID documents
        ParticipantAControlPlane ->> VcIssuersDidDocument : query DID document
        activate VcIssuersDidDocument
        VcIssuersDidDocument -->> ParticipantAControlPlane : DID document containing VC verification methods
        deactivate VcIssuersDidDocument
        ParticipantAControlPlane ->> ParticipantAControlPlane : verify VCs and\nenforce policies
    end
    ParticipantAControlPlane -->> FederatedCatalog : return list  of datasets
    FederatedCatalog ->> FederatedCatalog : Cache datasets\nin-memory
end

@enduml


