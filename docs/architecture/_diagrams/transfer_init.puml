@startuml

skinParam NoteBackgroundColor WhiteSmoke
skinParam NoteFontColor Black
skinParam ParticipantBackgroundColor WhiteSmoke
skinParam ActorBackgroundColor WhiteSmoke
skinParam AgentBackgroundColor White
skinParam AgentBorderColor SkyBlue
skinparam shadowing false
skinparam BoxPadding 10

!define ParticipantAColor f8f2ff
!define ParticipantBColor d9edff
!define VCIssuersColor D5F5E3
!define DataspaceAuthorityColor FCF3CF
!define WarningColor Business
!define LeadColor Technology

autonumber

box "VC Issuers" #VCIssuersColor
    participant VcIssuersDidDocument as "DID Document"
end box

actor ParticipantA as "Participant A"

box "Participant A ecosystem" #ParticipantAColor
    database ParticipantADatabase as "Database"
    database ParticipantAVault as "Vault"
    participant ParticipantAIdentityHub as "Identity Hub" #Business
    participant ParticipantAControlPlane as "Control Plane" #Business
    participant ParticipantADataPlane as "Data Plane" #Business
end box

box "Participant B ecosystem" #ParticipantBColor
    participant ParticipantBDataPlane as "Data Plane" #Business
    participant ParticipantBControlPlane as "Control Plane" #Business
    participant ParticipantBIdentityHub as "Identity Hub" #Business
    database ParticipantBDatabase as "Database"
    database ParticipantBVault as "Vault"
end box

autonumber 1

ParticipantA ->> ParticipantAControlPlane : initiate transfer
activate ParticipantA
activate ParticipantAControlPlane

ParticipantAControlPlane ->> ParticipantAControlPlane : validate query
ParticipantAControlPlane --> ParticipantA : acknowledge
deactivate ParticipantA
ParticipantAControlPlane ->> ParticipantBControlPlane : transfer init query
activate ParticipantBControlPlane

group Verify VCs
    ParticipantBControlPlane ->> ParticipantAIdentityHub : fetch Verifiable Credentials
    activate ParticipantAIdentityHub
    ParticipantAIdentityHub -->> ParticipantBControlPlane : return list of VCs
    ParticipantBControlPlane ->> ParticipantBControlPlane : resolve issuers\nDID documents
    ParticipantBControlPlane ->> VcIssuersDidDocument : query DID documents
    activate VcIssuersDidDocument
    VcIssuersDidDocument -->> ParticipantBControlPlane : DID document containing VC verification methods
    deactivate VcIssuersDidDocument
    ParticipantBControlPlane ->> ParticipantBControlPlane : verify VCs
end
ParticipantBControlPlane ->> ParticipantBDatabase : fetch contract
ParticipantBDatabase --> ParticipantBControlPlane : contract
ParticipantBControlPlane ->> ParticipantBControlPlane : check contract\npolicy valid
ParticipantBControlPlane ->> ParticipantBControlPlane : generate access\ntoken

ParticipantBControlPlane ->> ParticipantBDatabase : store transfer process
activate ParticipantBDatabase
ParticipantBControlPlane ->> ParticipantAControlPlane : send transfer process + acces token
ParticipantAControlPlane ->> ParticipantADatabase : store transfer process
activate ParticipantADatabase
ParticipantAControlPlane ->> ParticipantAVault : store access token
activate ParticipantAVault


@enduml