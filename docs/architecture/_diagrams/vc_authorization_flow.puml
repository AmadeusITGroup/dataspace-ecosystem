@startuml

skinParam NoteBackgroundColor WhiteSmoke
skinParam NoteFontColor Black
skinParam ParticipantBackgroundColor WhiteSmoke
skinParam ActorBackgroundColor WhiteSmoke
skinParam AgentBackgroundColor White
skinParam AgentBorderColor SkyBlue
skinparam shadowing false
skinparam BoxPadding 10

!define ParticipantAColor f8f2ff
!define ParticipantBColor d9edff
!define VCIssuersColor D5F5E3
!define DataspaceAuthorityColor FCF3CF
!define WarningColor Business
!define LeadColor Technology

autonumber

box "VC Issuers" #VCIssuersColor
    participant VcIssuersIdentityHub as "Identity Hub" #Business
end box

box "Participant A ecosystem" #ParticipantAColor
    participant ParticipantAIdentityHub as "Identity Hub" #Business
    participant ParticipantAControlPlane as "Control Plane" #Business
end box

box "Participant B ecosystem" #ParticipantBColor
    participant ParticipantBControlPlane as "Control Plane" #Business
    participant ParticipantBIdentityHub as "Identity Hub" #Business
end box

autonumber 1

ParticipantAControlPlane ->> ParticipantBControlPlane : request (contract negotiation, catalog...)
activate ParticipantAControlPlane
activate ParticipantBControlPlane
ParticipantBControlPlane ->> ParticipantBControlPlane : resolve DID url\nfrom request
ParticipantBControlPlane ->> ParticipantAIdentityHub : resolve DID document
activate ParticipantAIdentityHub
ParticipantAIdentityHub -->> ParticipantBControlPlane : DID document
deactivate ParticipantAIdentityHub
ParticipantBControlPlane ->> ParticipantAIdentityHub : query VCs
activate ParticipantAIdentityHub
ParticipantAIdentityHub -->> ParticipantBControlPlane : VCs
deactivate ParticipantAIdentityHub
ParticipantBControlPlane ->> ParticipantBControlPlane : resolve issuers\nDID documents
ParticipantBControlPlane ->> VcIssuersIdentityHub : query DID documents
activate VcIssuersIdentityHub
VcIssuersIdentityHub -->> ParticipantBControlPlane : DID document containing VC verification methods
deactivate VcIssuersIdentityHub
ParticipantBControlPlane ->> ParticipantBControlPlane : verify VCs and\nenforce policies
ParticipantBControlPlane ->> ParticipantAControlPlane : response if authentication\nsuccessful, error message otherwise


@enduml