@startuml

skinParam NoteBackgroundColor WhiteSmoke
skinParam NoteFontColor Black
skinParam ParticipantBackgroundColor WhiteSmoke
skinParam ActorBackgroundColor WhiteSmoke
skinParam AgentBackgroundColor White
skinParam AgentBorderColor SkyBlue
skinparam shadowing false
skinparam BoxPadding 10

!define ParticipantAColor f8f2ff
!define ParticipantBColor d9edff
!define VCIssuersColor D5F5E3
!define DataspaceAuthorityColor FCF3CF
!define WarningColor Business
!define LeadColor Technology

autonumber

box "Participant ecosystem" #ParticipantAColor
    participant ParticipantDataPlane as "Data Plane" #Business
    participant ParticipantTelemetryAgent as "Telemetry\nAgent" #Business
    database ParticipantVault as "Vault"
    database ParticipantDB as "DB"
end box

box "DSE" #DataspaceAuthorityColor
    participant DseEventBroker as "Event Broker"
    participant DseTelemetryService as "Telemetry\nService" #Business
end box

autonumber 1


ParticipantDataPlane ->> ParticipantDB : data consumption record
activate ParticipantDB
activate ParticipantDataPlane
ParticipantDB -->> ParticipantDataPlane : acknowledge
deactivate ParticipantDataPlane
deactivate ParticipantDB



@enduml